# ════════════════════════════════════════
#  Dawn Bot - Environment Variables
#  Copy this to .env for local testing
#  On Railway: add these in Variables tab
# ════════════════════════════════════════

# ── Telegram Bot ─────────────────────────
BOT_TOKEN=YOUR_BOT_TOKEN           # From @BotFather
ADMIN_ID=YOUR_TELEGRAM_USER_ID     # From @userinfobot
CHANNEL=@your_channel              # Your Telegram channel

# ── Telegram API (Telethon) ──────────────
API_ID=YOUR_API_ID                 # From my.telegram.org
API_HASH=YOUR_API_HASH             # From my.telegram.org
PHONE=+251XXXXXXXXX                # Your phone number
SESSION_STRING=                    # Auto-generated after /auth

# ── Proxy (for YouTube downloads) ───────
PROXY_URL=                         # http://user:pass@host:port

# ── TikTok Integration ───────────────────
TIKTOK_CLIENT_KEY=                 # From developers.tiktok.com
TIKTOK_CLIENT_SECRET=              # From developers.tiktok.com
TIKTOK_REDIRECT_URI=https://your-app.railway.app/tiktok/callback
TIKTOK_VERIFY_TOKEN=tiktok-developers-site-verification=YOUR_TOKEN

# ── Gemini AI ────────────────────────────
GEMINI_API_KEY=                    # From aistudio.google.com
